# ===== Model Configuration =====
# Set to "openai" or "ollama"
LLM_BACKEND=ollama

# OpenAI Configuration (only if LLM_BACKEND=openai)
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1

# Model Selection
CTF_MODEL=llama3.1:8b              # ollama: llama3.1:8b | openai: gpt-4.1-mini
CTF_VISION_MODEL=llama3.2-vision:11b  # ollama: llama3.2-vision:11b | openai: gpt-4.1-mini

# ===== Port Configuration =====
OLLAMA_PORT=11435                   # Changed from 11434 to avoid local conflict
OPENWEBUI_PORT=4242
PIPELINES_PORT=9099
CTF_JUPYTER_PORT=8888
NOTEBOOKS_PORT=8889

# ===== CTF Configuration =====
